# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=documents

# document-service
DOCUMENT_DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/documents
SECRET_KEY=change-this-secret-key-in-production

# auth-service
AUTH_DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/auth

# notification-service
NOTIFICATION_DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/notifications

# RabbitMQ
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=password
RABBITMQ_URL=amqp://admin:password@rabbitmq:5672/

# Redis
REDIS_URL=redis://redis:6379

# OpenAI (optional — leave blank to use extractive fallback)
OPENAI_API_KEY=
