# Copy this file to .env and fill in every value before starting in production.
# NEVER commit your .env file — it is gitignored.

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=documents

DOCUMENT_DATABASE_URL=postgresql+asyncpg://postgres:change-me-strong-password@postgres:5432/documents
AUTH_DATABASE_URL=postgresql+asyncpg://postgres:change-me-strong-password@postgres:5432/auth
NOTIFICATION_DATABASE_URL=postgresql+asyncpg://postgres:change-me-strong-password@postgres:5432/notifications

# ── Application secret (JWT signing) ────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-hex-chars

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq-password
RABBITMQ_URL=amqp://admin:change-me-rabbitmq-password@rabbitmq:5672/

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379

# ── OpenAI (optional — enables GPT summarisation and tag suggestion) ─────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Grafana ──────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-password
GF_ROOT_URL=https://grafana.yourdomain.com
