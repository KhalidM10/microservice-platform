DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/documents
APP_NAME=document-service
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
RABBITMQ_URL=amqp://admin:password@localhost:5672/
REDIS_URL=redis://localhost:6379
# Required for AI summarisation (gpt-4o-mini) and tag suggestions.
# Get your key at https://platform.openai.com/api-keys
# Without this key the service falls back to extractive summarisation and returns empty tag suggestions.
OPENAI_API_KEY=sk-...
